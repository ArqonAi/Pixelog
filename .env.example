# Production environment variables
NODE_ENV=production
GIN_MODE=release
PORT=8080

# Security settings
CORS_ORIGINS=https://yourdomain.github.io,https://yourdomain.com
MAX_FILE_SIZE=100MB
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60s

# Optional features
ENABLE_METRICS=false
LOG_LEVEL=info

# AI/Embedding Provider Configuration (choose one)
# OpenAI (text-embedding-3-small, 1536 dimensions)
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenRouter (supports multiple models)
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here
OPENROUTER_MODEL=text-embedding-3-small

# Google Gemini
GOOGLE_API_KEY=your-gemini-api-key-here

# xAI Grok
XAI_API_KEY=xai-your-grok-key-here

# Local Ollama (no API key required)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text

# Provider priority (first available will be used)
EMBEDDING_PROVIDER=auto  # auto, openai, openrouter, google, grok, ollama

# Encryption Configuration
ENCRYPTION_ENABLED=false
DEFAULT_PASSWORD=  # Optional: default password for encryption (leave empty for user-provided)

# Cloud Storage Configuration (choose one)
CLOUD_PROVIDER=s3  # s3, gcs, azure

# AWS S3 Configuration
S3_BUCKET=my-pixelog-bucket
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_ENDPOINT=  # Optional: for S3-compatible services like DigitalOcean Spaces

# Google Cloud Storage Configuration  
GCS_BUCKET=my-pixelog-bucket
GOOGLE_PROJECT_ID=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Azure Blob Storage Configuration
AZURE_STORAGE_ACCOUNT=your-storage-account
AZURE_CONTAINER=pixelog
AZURE_STORAGE_KEY=your-azure-storage-key